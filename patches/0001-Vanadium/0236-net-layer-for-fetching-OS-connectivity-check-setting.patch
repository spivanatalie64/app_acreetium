@@ -0,0 +1,18 @@
+#include "net/downstream/conn_checks/android/conn_checks_util.h"
+
+#include "base/android/jni_android.h"
+
+#include "net/downstream/conn_checks/android/conn_checks_util_jni_headers/ConnChecksUtil_jni.h"
+
+namespace net::android {
+
+ConnChecksOsSetting GetConnChecksOsSetting() {
+  JNIEnv* env = base::android::AttachCurrentThread();
+  int setting = Java_ConnChecksUtil_getConnChecksSetting(env);
+  return (setting < GRAPHENEOS || setting > DISABLED)
+            ? DEFAULT : static_cast<ConnChecksOsSetting>(setting);
+}
+
+} // namespace net::android
+
+DEFINE_JNI(ConnChecksUtil)
