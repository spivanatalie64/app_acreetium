 .../android/site_settings_android_java_ext_deps.gni        | 6 ++++++
 .../android/site_settings_android_java_ext_sources.gni     | 6 ++++++
 .../android/site_settings_android_java_ext_srcjar_deps.gni | 6 ++++++
 4 files changed, 25 insertions(+)
