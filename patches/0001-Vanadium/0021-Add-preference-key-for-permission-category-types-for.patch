From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: quh4gko8 <88831734+quh4gko8@users.noreply.github.com>
Date: Tue, 14 Apr 2026 14:46:24 +0000
Subject: [PATCH] Add preference key for permission category types for site
 settings UI

---
 .../android/java/res/xml/site_settings_preferences.xml    | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/components/browser_ui/site_settings/android/java/res/xml/site_settings_preferences.xml b/components/browser_ui/site_settings/android/java/res/xml/site_settings_preferences.xml
index 2937c88902961..aedb1aaa3781b 100644
--- a/components/browser_ui/site_settings/android/java/res/xml/site_settings_preferences.xml
+++ b/components/browser_ui/site_settings/android/java/res/xml/site_settings_preferences.xml
@@ -19,7 +19,9 @@ The order of the following items is from: http://crbug.com/610358.
         app:iconTint="@macro/default_icon_color" />
 
     <!-- PERMISSIONS section -->
-    <PreferenceCategory android:title="@string/site_settings_permission_category"/>
+    <PreferenceCategory
+        android:title="@string/site_settings_permission_category"
+        android:key="permission_category" />
     <!-- Location -->
     <org.chromium.components.browser_ui.settings.ChromeBasePreference
         android:fragment="org.chromium.components.browser_ui.site_settings.SingleCategorySettings"
@@ -108,7 +110,9 @@ The order of the following items is from: http://crbug.com/610358.
         android:key="loopback_network" />
 
     <!-- CONTENT SETTINGS section -->
-    <PreferenceCategory android:title="@string/site_settings_content_category"/>
+    <PreferenceCategory
+        android:title="@string/site_settings_content_category"
+        android:key="content_category" />
     <!-- Third party cookies -->
     <org.chromium.components.browser_ui.settings.ChromeBasePreference
         android:key="third_party_cookies"
