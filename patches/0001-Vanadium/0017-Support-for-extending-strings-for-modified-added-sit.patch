From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: fgei <fgei@gmail.com>
Date: Tue, 28 Jan 2025 13:00:22 +0000
Subject: [PATCH] Support for extending strings for modified/added site
 settings

---
 components/browser_ui/strings/android/browser_ui_strings.grd | 1 +
 components/browser_ui/strings/android/site_settings_ext.grdp | 3 +++
 2 files changed, 4 insertions(+)
 create mode 100644 components/browser_ui/strings/android/site_settings_ext.grdp

diff --git a/components/browser_ui/strings/android/browser_ui_strings.grd b/components/browser_ui/strings/android/browser_ui_strings.grd
index e403b4e16682f..f881a56b13164 100644
--- a/components/browser_ui/strings/android/browser_ui_strings.grd
+++ b/components/browser_ui/strings/android/browser_ui_strings.grd
@@ -174,6 +174,7 @@
   <release seq="1">
     <messages fallback_to_english="true">
       <part file="site_settings.grdp" />
+      <part file="site_settings_ext.grdp" />
 
       <message name="IDS_GOT_IT" desc="Button for the user to accept a disclosure/message" formatter_data="android_java">
         Got it
diff --git a/components/browser_ui/strings/android/site_settings_ext.grdp b/components/browser_ui/strings/android/site_settings_ext.grdp
new file mode 100644
index 0000000000000..4f00e4661d3cf
--- /dev/null
+++ b/components/browser_ui/strings/android/site_settings_ext.grdp
@@ -0,0 +1,3 @@
+<?xml version="1.0" encoding="utf-8"?>
+<grit-part>
+</grit-part>
