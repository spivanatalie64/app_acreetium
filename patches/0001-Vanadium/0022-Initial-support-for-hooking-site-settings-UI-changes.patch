+            if (title == noResOverride) {
+                title = origResItem.getTitle();
+            }
+            if (defaultEnabledValue == ContentSetting.DEFAULT) {
+                defaultEnabledValue = origResItem.getDefaultEnabledValue();
+            }
+            if (defaultDisabledValue == ContentSetting.DEFAULT) {
+                defaultDisabledValue = origResItem.getDefaultDisabledValue();
+            }
+            if (enabledSummary == noResOverride) {
+                enabledSummary = origResItem.getEnabledSummary();
+            }
+            if (disabledSummary == noResOverride) {
+                disabledSummary = origResItem.getDisabledSummary();
+            }
+            if (summaryOverrideForScreenReader == noResOverride) {
+                summaryOverrideForScreenReader = origResItem.getSummaryOverrideForScreenReader();
+            }
+            if (iconBlocked == noResOverride) {
+                iconBlocked = origResItem.getIconBlocked();
+            }
+            if (enabledPrimaryText == noResOverride) {
+                enabledPrimaryText = origResItem.getEnabledPrimaryText();
+            }
+            if (disabledPrimaryText == noResOverride) {
+                disabledPrimaryText = origResItem.getDisabledPrimaryText();
+            }
+            if (disabledDescriptionText == noResOverride) {
+                disabledDescriptionText = origResItem.getDisabledDescriptionText();
+            }
+        }
+
+        ResourceItem resourceItem = new ResourceItem(
+                icon,
+                title,
+                defaultEnabledValue,
+                defaultDisabledValue,
+                enabledSummary,
+                disabledSummary,
+                summaryOverrideForScreenReader,
+                iconBlocked,
+                enabledPrimaryText,
+                disabledPrimaryText);
+        if (disabledDescriptionText == 0 || disabledDescriptionText == noResOverride) {
+            return resourceItem;
+        }
+
+        return resourceItem.setDisabledDescriptionText(disabledDescriptionText);
+    }
