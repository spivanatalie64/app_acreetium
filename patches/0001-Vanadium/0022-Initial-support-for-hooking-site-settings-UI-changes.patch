+package org.chromium.components.browser_ui.site_settings;
+
+import androidx.annotation.IntDef;
+import androidx.preference.Preference;
+
+import org.chromium.build.annotations.AlwaysInline;
+import org.chromium.build.annotations.NonNull;
+import org.chromium.build.annotations.NullMarked;
+import org.chromium.build.annotations.Nullable;
+import org.chromium.components.browser_ui.settings.ChromeBasePreference;
+import org.chromium.components.content_settings.ContentSettingsType;
+
+@NullMarked
+public class SingleCategorySettingsHooks {
+
+    private static final class LazyHolder {
+        @NonNull
+        private static final SingleCategorySettingsHooks DEF_INSTANCE =
+                new SingleCategorySettingsHooks();
+    }
+
+    protected SingleCategorySettingsHooks() {
+    }
+
+    protected final boolean isDefaultInstance() {
+        return this == getDefaultInstance();
+    }
+
+    @NonNull
+    protected static final SingleCategorySettingsHooks getDefaultInstance() {
+        return LazyHolder.DEF_INSTANCE;
+    }
+
+    static final int NONE = -1;
+    static final int BINARY_RADIO_BUTTON = 0;
+    static final int TRI_STATE_TOGGLE = 1;
+    static final int OTHER_LAYOUT_TOGGLE = 2;
+
+    @IntDef({
+        NONE,
+        BINARY_RADIO_BUTTON,
+        TRI_STATE_TOGGLE,
+        OTHER_LAYOUT_TOGGLE,
+    })
+    @interface GlobalToggleLayoutOverride {
+    }
+
+    @GlobalToggleLayoutOverride
+    protected int getGlobalToggleLayoutOverride() {
+        return NONE;
+    }
+
+    @Nullable
+    protected Boolean shouldAddExceptionButton(boolean isCategoryEnabled) {
+        return null;
+    }
+
+    protected int getAddExceptionDialogMessageResourceId(boolean isCategoryEnabled) {
+        return SiteSettingsResourcesHooks.NO_RES_OVERRIDE;
+    }
+
+    protected boolean shouldAlwaysShowOsWarning() {
+        return false;
+    }
+}
