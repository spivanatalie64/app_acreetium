+package org.chromium.components.browser_ui.site_settings;
+
+import android.content.Context;
+
+import androidx.preference.Preference;
+import androidx.preference.PreferenceScreen;
+
+import org.chromium.build.NullUtil;
+import org.chromium.build.annotations.AlwaysInline;
+import org.chromium.build.annotations.NonNull;
+import org.chromium.build.annotations.NullMarked;
+import org.chromium.build.annotations.Nullable;
+import org.chromium.components.browser_ui.settings.ChromeBasePreference;
+import org.chromium.components.content_settings.ContentSettingsType;
+import org.chromium.content_public.browser.BrowserContextHandle;
+
+@NullMarked
+public class SiteSettingsScreenHooks {
+
+    private static final class LazyHolder {
+        @NonNull
+        private static final SiteSettingsScreenHooks DEF_INSTANCE =
+                new SiteSettingsScreenHooks();
+    }
+
+    protected SiteSettingsScreenHooks() {
+    }
+
+    protected final boolean isDefaultInstance() {
+        return this == getDefaultInstance();
+    }
+
+    @NonNull
+    protected static final SiteSettingsScreenHooks getDefaultInstance() {
+        return LazyHolder.DEF_INSTANCE;
+    }
+
+    @ContentSettingsType.EnumType
+    protected int getPreviousContentSettings() {
+        return ContentSettingsType.MAX_VALUE;
+    }
+
+    protected boolean isIndexable() {
+        return true;
+    }
+
+    protected void configureSiteSettingsPreference(
+            @NonNull SiteSettings siteSettingsFragment,
+            @NonNull SiteSettingsDelegate siteSettingsDelegate,
+            @SiteSettingsCategory.Type int categoryType,
+            @Nullable Preference existingPreference) {
+    }
+
+    protected void updateSiteSettingsPreference(
+            @NonNull SiteSettings siteSettingsFragment,
+            @NonNull SiteSettingsDelegate siteSettingsDelegate,
+            @NonNull Preference existingPreference) {
+    }
+
+    protected final ChromeBasePreference defaultCreatePreference(
+            @NonNull SiteSettings siteSettingsFragment,
+            @NonNull String prefKey) {
+        Context prefCtx = siteSettingsFragment.requireContext();
+        ChromeBasePreference pref = new ChromeBasePreference(prefCtx);
+        String fragmentName = "org.chromium.components.browser_ui.site_settings.SingleCategorySettings";
+        pref.setFragment(fragmentName);
+        pref.setKey(prefKey);
+        return pref;
+    }
+
+    protected final void addPreference(
+            @NonNull SiteSettings siteSettingsFragment,
+            @NonNull SiteSettingsDelegate siteSettingsDelegate,
+            @SiteSettingsCategory.Type int categoryType,
+            @NonNull Preference pref) {
+        PreferenceScreen preferenceScreen = siteSettingsFragment.getPreferenceScreen();
+        int prevContentSetting = getPreviousContentSettings();
+        int curContentSetting = SiteSettingsCategory.contentSettingsType(categoryType);
+        WebsitePermissionsFetcher.WebsitePermissionsType permissionsType =
+                WebsitePermissionsFetcher.getPermissionsType(curContentSetting);
+        int prefCount = preferenceScreen.getPreferenceCount();
+        final int orderDefault;
+        if (permissionsType == null) {
+            orderDefault = prefCount - 2;
+        } else if (permissionsType == WebsitePermissionsFetcher.WebsitePermissionsType.PERMISSION_INFO) {
+            Preference permissionGroup = preferenceScreen.findPreference("content_category");
+            orderDefault = permissionGroup.getOrder() - 2;
+        } else {
+            orderDefault = prefCount - 2;
+        }
+        if (prevContentSetting >= ContentSettingsType.MAX_VALUE) {
+            addPreferenceInner(preferenceScreen, pref, orderDefault);
+            return;
+        }
+
+        SiteSettingsCategory prevCategory = SiteSettingsCategory.createFromContentSettingsType(
+                siteSettingsDelegate.getBrowserContextHandle(), prevContentSetting);
+        if (prevCategory == null) {
+            addPreferenceInner(preferenceScreen, pref, orderDefault);
+            return;
+        }
+
+        String prevPrefKey = SiteSettingsCategory.preferenceKey(prevCategory.getType());
+        Preference prevPref = NullUtil.assertNonNull(siteSettingsFragment.findPreference(prevPrefKey));
+        int prevOrder = prevPref.getOrder();
+        addPreferenceInner(preferenceScreen, pref, prevOrder);
+    }
+
+    private final void addPreferenceInner(@NonNull PreferenceScreen preferenceScreen,
+            @NonNull Preference pref, int prevOrder) {
+        pref.setOrder(prevOrder + 1);
+        preferenceScreen.addPreference(pref);
+    }
+}
+
