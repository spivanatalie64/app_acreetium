+        return this == getDefaultInstance();
+    }
+
+    @NonNull
+    protected static final WebsitePermissionsFetcherHooks getDefaultInstance() {
+        return LazyHolder.DEF_INSTANCE;
+    }
+
+    static final int UNKNOWN = -1;
+    static final int CONTENT_SETTING_EXCEPTION = 0;
+    static final int PERMISSION_INFO = 1;
+    static final int CHOSEN_OBJECT_INFO = 2;
+
+    @IntDef({
+        UNKNOWN,
+        CONTENT_SETTING_EXCEPTION,
+        PERMISSION_INFO,
+        CHOSEN_OBJECT_INFO,
+    })
+    @interface PermissionTypeOverride {
+    }
+
+    @PermissionTypeOverride
+    protected int getPermissionTypeOverride() {
+        return UNKNOWN;
+    }
+
+    protected boolean shouldCreateExceptionIfNull() {
+        return false;
+    }
